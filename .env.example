# ── Firebase Admin (server-side, nunca expor ao cliente) ──────────────────────
# Encontre em: Firebase Console > Configurações do projeto > Contas de serviço > Gerar nova chave privada
NUXT_FIREBASE_PROJECT_ID=
NUXT_FIREBASE_CLIENT_EMAIL=
# Cole a chave privada com \n literal (não quebra de linha real)
NUXT_FIREBASE_PRIVATE_KEY=

# ── Firebase Client (público, exposto ao browser) ─────────────────────────────
# Encontre em: Firebase Console > Configurações do projeto > Seus apps > SDK setup
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
